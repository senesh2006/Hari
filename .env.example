# Copy to Vercel environment variables (and local .env if using vercel dev)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# AssemblyAI — English speech-to-text (mic); not used for TTS
ASSEMBLYAI_API_KEY=
# Optional: universal-3-pro (default), best, nano
ASSEMBLYAI_SPEECH_MODEL=universal-3-pro
# Voice Agent TTS voice for English replies (ivy, james, tyler, sophie, …)
ASSEMBLYAI_VOICE=ivy

# Existing keys
GEMINI_API_KEY=
# Optional: also accepts GOOGLE_API_KEY
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_PRIMARY=gemini
NVIDIA_API_KEY=
CAMB_API_KEY=
LANGBLY_API_KEY=

# Gift strategy layer (optional). Defaults to the main NIM model/key, so leaving
# these unset still works. Point them at a separate (e.g. second 70B) deployment
# to split the strategy step from the search step.
# STRATEGY_ENABLED=1
# STRATEGY_NIM_MODEL=meta/llama-3.3-70b-instruct
# STRATEGY_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# STRATEGY_NIM_API_KEY=
# STRATEGY_TIMEOUT=18

# Web trends refresh (api/refresh_trends.py, daily Vercel Cron)
# Tavily search API key — https://tavily.com (free tier is plenty for a daily cron)
TAVILY_API_KEY=
# Supabase service-role key — lets the cron write the global trends_cache row.
# Supabase: Project Settings -> API -> service_role secret. Keep server-side only.
SUPABASE_SERVICE_ROLE_KEY=
# Shared secret protecting /api/refresh_trends; Vercel Cron sends it automatically.
CRON_SECRET=
