# Copy to Vercel environment variables (and local .env if using vercel dev)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# AssemblyAI — English speech-to-text (mic); not used for TTS
ASSEMBLYAI_API_KEY=
# Optional: universal-3-pro (default), best, nano
ASSEMBLYAI_SPEECH_MODEL=universal-3-pro
# Voice Agent TTS voice for English replies (ivy, james, tyler, sophie, …)
ASSEMBLYAI_VOICE=ivy

# Existing keys
NVIDIA_API_KEY=
CAMB_API_KEY=
LANGBLY_API_KEY=

# Web trends refresh (api/refresh_trends.py, daily Vercel Cron)
# Tavily search API key — https://tavily.com (free tier is plenty for a daily cron)
TAVILY_API_KEY=
# Supabase service-role key — lets the cron write the global trends_cache row.
# Supabase: Project Settings -> API -> service_role secret. Keep server-side only.
SUPABASE_SERVICE_ROLE_KEY=
# Shared secret protecting /api/refresh_trends; Vercel Cron sends it automatically.
CRON_SECRET=
