{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/search.py": { "maxDuration": 60 },
    "api/tool.py": { "maxDuration": 30 },
    "api/check.py": { "maxDuration": 30 },
    "api/tts.py": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
